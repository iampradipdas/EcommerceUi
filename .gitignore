# ============================================================
# .gitignore for EcommerceUi — Angular + TypeScript
# ============================================================

# --------------------------
# Compiled Output
# --------------------------
/dist
/tmp
/out-tsc
/bazel-out
*.js.map

# --------------------------
# Node / NPM
# --------------------------
/node_modules
npm-debug.log
npm-debug.log.*
yarn-error.log
yarn-error.log.*
package-lock.json
# Uncomment the line below if you use Yarn:
# yarn.lock
.pnp
.pnp.js

# --------------------------
# Angular Cache
# --------------------------
/.angular/cache
.angular/

# --------------------------
# IDEs and Editors
# --------------------------

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# JetBrains / WebStorm / Rider
.idea/
*.iml

# Sublime Text
*.sublime-workspace
*.sublime-project

# Eclipse
.project
.classpath
.c9/
.settings/
*.launch

# --------------------------
# Testing & Coverage
# --------------------------
/coverage
*.lcov
/e2e/test-results
/e2e/screenshots
__screenshots__/
testem.log
/typings

# --------------------------
# Sass / CSS Build
# --------------------------
.sass-cache/
*.css.map

# --------------------------
# Miscellaneous
# --------------------------
/connect.lock
/libpeerconnection.log

# --------------------------
# Environment / Secrets
# --------------------------
src/environments/environment.prod.ts
src/environments/environment.staging.ts
.env
.env.*
!.env.example

# --------------------------
# OS & System Files
# --------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------------------
# Temporary Files
# --------------------------
*.swp
*.swo
*~
